# Пример конфигурации Wareon.
# Скопируй этот файл в data/.env и подставь свои значения:
#   cp data/.env.example data/.env
# Папка data/ — в .gitignore, поэтому реальные токены в репозиторий не попадут.

# Токен бота из @BotFather
BOT_TOKEN=1234567890:AAAA-your-token-here

# Файл базы данных SQLite (по умолчанию лежит в data/)
DATABASE_PATH=data/wareon.db

# Полный адрес БД — для продакшена (несколько клиентов). Если задан,
# используется вместо DATABASE_PATH. Пример для PostgreSQL:
# DATABASE_URL=postgresql+asyncpg://user:pass@host:5432/wareon
DATABASE_URL=

# Разрешённые источники для API (CORS) — обычно адрес дашборда.
# Пример: CORS_ORIGINS=https://wareon-top.github.io
CORS_ORIGINS=*

# Ключ Anthropic для ИИ-функций (сводка, ассистент). Взять на console.anthropic.com.
# Пусто — ИИ выключен, остальной бот работает.
ANTHROPIC_API_KEY=
AI_MODEL=claude-opus-4-8

# HTTPS-адрес мини-приложения (Web App). Когда задан — в боте появляется
# кнопка «Открыть дашборд».
WEBAPP_URL=https://wareon-top.github.io/proekt1/
